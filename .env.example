# ============================================================
# Bolão Copa 2026 — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o .env com credenciais reais.
# ============================================================

# ── APLICAÇÃO ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOCAL_DB_PATH=/tmp/bolao/local.db

# ── AUTENTICAÇÃO ─────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque-esta-chave-por-uma-segura-em-producao

# ── CONTA ADMIN PADRÃO ───────────────────────────────────────
ADMIN_EMAIL=admin@bolao.local
ADMIN_PASSWORD=admin123
ADMIN_NAME=Organizador

# ── TURSO (banco de dados remoto) ────────────────────────────
# Obtenha em: https://turso.tech
TURSO_DATABASE_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=seu-token-turso-aqui

# ── SMTP (e-mail) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-de-app
SMTP_FROM=bolao@gmail.com
